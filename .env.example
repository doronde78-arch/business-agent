# Anthropic API Key - required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Business details - shown on quotes and invoices
BUSINESS_NAME=שם העסק שלי
BUSINESS_ADDRESS=רחוב הדוגמא 1, תל אביב
BUSINESS_PHONE=050-0000000
BUSINESS_EMAIL=business@example.com
BUSINESS_TAX_ID=123456789  # מספר עוסק מורשה

# SMTP settings for sending emails (optional)
# If not set, files are saved locally only
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SENDER_NAME=שם העסק שלי
SENDER_EMAIL=your_email@gmail.com

# VAT rate (default: 0.18 = 18%)
VAT_RATE=0.18

# Currency symbol (default: ₪)
CURRENCY=₪
